# Grab this from neon.tech, to connect to the remote database
# This is used for the main and only database of this app
DATABASE_URL=""

# Public app URL used by Better Auth, for example http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth credentials
# Add this authorized redirect URI in Google Cloud:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# A random secret to keep the authentication secure
# Can be generated with 'openssl rand -base64 32'
BETTER_AUTH_SECRET=""

# Cloudflare R2 bucket (S3-compatible) for user-uploaded documents.
# Create an R2 API token with Object Read & Write for the bucket below.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# OpenAI API key, used for document analysis and the automatic ISEEU agent.
OPENAI_API_KEY=""
# Optional: override the model used for document analysis (default: gpt-4o).
OPENAI_ANALYSIS_MODEL="gpt-4o"
# Optional: override the model used by the streamed automatic-calculation agent.
OPENAI_AUTOMATIC_MODEL="gpt-5.4"
